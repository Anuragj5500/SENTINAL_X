# ─────────────────────────────────────────────────────
# SentinelX SIEM — Environment Configuration
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────

# Application
APP_NAME=SentinelX
APP_VERSION=1.0.0
DEBUG=false

# Security — generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-to-a-very-long-random-secret-key-at-least-64-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
# SQLite (default, zero-config):
DATABASE_URL=sqlite+aiosqlite:///./sentinelx.db
# PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/sentinelx

# CORS — comma-separated allowed origins
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://localhost:8080"]

# ─────────────── Threat Intelligence APIs ─────────────
# VirusTotal — https://www.virustotal.com/gui/join-us
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# AbuseIPDB — https://www.abuseipdb.com/account/api
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here

# AlienVault OTX — https://otx.alienvault.com/api
OTX_API_KEY=your_alienvault_otx_key_here

# Shodan — https://account.shodan.io/
SHODAN_API_KEY=your_shodan_api_key_here

# ─────────────── AI / LLM ─────────────────────────────
# Google Gemini — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI (GPT-4) — https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ─────────────── Notifications ────────────────────────
# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your-app-password

# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# ─────────────── Performance ──────────────────────────
MAX_EVENTS_PER_SECOND=10000
ALERT_RETENTION_DAYS=90
LOG_RETENTION_DAYS=365
DEFAULT_PAGE_SIZE=50
MAX_PAGE_SIZE=500
